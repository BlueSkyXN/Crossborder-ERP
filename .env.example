DJANGO_SECRET_KEY=dev-secret-change-in-real-env-please-keep-at-least-32-bytes
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=true
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_PERMISSIONS_POLICY=camera=(),microphone=(),geolocation=(),payment=(),usb=()
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_SECURE_SSL_REDIRECT=false

DATABASE_URL=sqlite:///./backend/db.sqlite3
# PostgreSQL/MySQL DSN examples are configuration-only and unverified until drivers/services are installed in a target env.
# DATABASE_URL=postgres://erp:secret@localhost:5432/crossborder
# DATABASE_URL=mysql://erp:secret@localhost:3306/crossborder
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=true
MEMBER_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
MEMBER_PASSWORD_RESET_EXPOSE_TOKEN=true

MEDIA_ROOT=./media
PUBLIC_BASE_URL=http://localhost:8000
ADMIN_WEB_URL=http://localhost:3001
USER_WEB_URL=http://localhost:3002
MOBILE_H5_URL=http://localhost:3003
